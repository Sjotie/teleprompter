#!/usr/bin/env sh
# Block commits that introduce secrets matching the gitleaks ruleset
# (including the custom RBPU-* rule defined in .gitleaks.toml).
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "❌ gitleaks is not installed. Run: brew install gitleaks"
  exit 1
fi
gitleaks protect --staged --redact --config .gitleaks.toml
